<Window x:Class="ScanApp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ScanApp.App.Views"
        Title="Actually Good Scanning App" Height="780" Width="1180"
        MinHeight="600" MinWidth="940"
        Background="{DynamicResource Bg}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" DragOver="OnDragOver" Drop="OnFilesDropped">

    <Window.InputBindings>
        <!-- Fast scanning + editing shortcuts. -->
        <KeyBinding Key="Return" Command="{Binding ScanCommand}" />
        <KeyBinding Key="F5" Command="{Binding ScanCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelScanCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveImagesCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="Left" Modifiers="Control" Command="{Binding PrevPageCommand}" />
        <KeyBinding Key="Right" Modifiers="Control" Command="{Binding NextPageCommand}" />
        <KeyBinding Key="R" Command="{Binding RotateSelectedRightCommand}" />
        <KeyBinding Key="R" Modifiers="Shift" Command="{Binding RotateSelectedLeftCommand}" />
    </Window.InputBindings>

    <Grid>
        <views:ScanView />
    </Grid>
</Window>
