<UserControl x:Class="ScanApp.App.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ScanApp.App.Controls">
    <UserControl.Resources>
        <!-- Segmented mode toggle: highlights the active mode. -->
        <Style x:Key="ModeButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Top bar ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Actually Good Scan" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,18,0" />
                <!-- Mode toggle (auto-set from scanner type; click to override) -->
                <Border Background="{StaticResource PanelAlt}" CornerRadius="9" Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SetFlatbedCommand}" Content="Flatbed">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlatbed}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Accent}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding SetSheetfedCommand}" Content="Sheetfed">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSheetfed}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Accent}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Open images" Command="{Binding OpenImagesCommand}" Style="{StaticResource GhostButton}"
                        Padding="14,10" Margin="0,0,10,0" />
                <Button Content="◼ Cancel" Command="{Binding CancelScanCommand}" Style="{StaticResource GhostButton}"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" Margin="0,0,10,0" />
                <Button Command="{Binding ScanCommand}" Style="{StaticResource PrimaryButton}"
                        MinWidth="160" Padding="22,12"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⤓  Scan" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="  (Enter)" FontSize="12" Opacity="0.8" VerticalAlignment="Center" Foreground="White" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Body: filmstrip | preview | options ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Filmstrip -->
            <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="10" Padding="6">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="6,4,6,8">
                        <TextBlock Text="Pages" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Clear" Command="{Binding ClearAllCommand}" HorizontalAlignment="Right"
                                Style="{StaticResource GhostButton}" Padding="8,4" FontSize="11" />
                    </Grid>
                    <ListBox ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelAlt}" CornerRadius="8" Padding="6" Margin="2,4">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding Number, StringFormat='Page {0}'}"
                                                       FontSize="11" Foreground="{StaticResource TextDim}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="⟲" Command="{Binding RotateLeftCommand}" ToolTip="Rotate left"
                                                        Style="{StaticResource GhostButton}" Padding="5,1" FontSize="11" Margin="0,0,3,0" />
                                                <Button Content="⟳" Command="{Binding RotateRightCommand}" ToolTip="Rotate right"
                                                        Style="{StaticResource GhostButton}" Padding="5,1" FontSize="11" Margin="0,0,3,0" />
                                                <Button Content="✕" Command="{Binding DeleteCommand}" ToolTip="Delete page"
                                                        Style="{StaticResource GhostButton}" Padding="5,1" FontSize="11" />
                                            </StackPanel>
                                        </Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" MaxHeight="160" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Preview -->
            <Border Grid.Column="1" Margin="12,0" Background="{StaticResource Panel}" CornerRadius="10">
                <Grid>
                    <TextBlock Text="Your scanned pages will appear here.&#10;Press Scan to begin, or Open images."
                               TextAlignment="Center" Foreground="{StaticResource TextDim}" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SelectedPage, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />
                    <Image Source="{Binding SelectedPage.Preview}" Stretch="Uniform" Margin="18"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <controls:CropOverlay Margin="18"
                                          ImagePixelWidth="{Binding SelectedPage.ImagePixelWidth}"
                                          ImagePixelHeight="{Binding SelectedPage.ImagePixelHeight}"
                                          IsActive="{Binding SelectedPage.IsCropActive}"
                                          CropRect="{Binding SelectedPage.CropRect, Mode=TwoWay}" />
                </Grid>
            </Border>

            <!-- Options -->
            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Scanner" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                                      DisplayMemberPath="Name" />
                            <Button Grid.Column="1" Content="⟳" Command="{Binding RefreshDevicesCommand}"
                                    ToolTip="Refresh device list" Style="{StaticResource GhostButton}" Padding="9,5" Margin="6,0,0,0" />
                        </Grid>
                        <!-- Empty-state: offer the demo scanner only when nothing is connected -->
                        <Button Content="No scanner detected — use demo scanner" Command="{Binding UseDemoCommand}"
                                Style="{StaticResource GhostButton}" Margin="0,8,0,0" FontSize="12"
                                Visibility="{Binding NoRealDevices, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Scan settings" FontWeight="SemiBold" Margin="0,18,0,6" />
                        <TextBlock Text="Resolution (DPI)" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding DpiOptions}" SelectedItem="{Binding Dpi}" Margin="0,2,0,8" />

                        <CheckBox Content="Colour" IsChecked="{Binding ColorScan}" Margin="0,3" />
                        <CheckBox Content="Duplex (both sides)" IsChecked="{Binding Duplex}" Margin="0,3"
                                  Visibility="{Binding IsSheetfed, Converter={StaticResource BoolToVis}}" />
                        <CheckBox Content="Auto-straighten (deskew)" IsChecked="{Binding AutoStraighten}" Margin="0,3" />
                        <CheckBox Content="Split multiple photos on glass" IsChecked="{Binding SplitMultiplePhotos}" Margin="0,3"
                                  Visibility="{Binding IsFlatbed, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Crop" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,10,0,2" />
                        <ComboBox ItemsSource="{Binding CropModes}" SelectedItem="{Binding SelectedCropMode}" />
                        <ComboBox ItemsSource="{Binding FixedSizes}" SelectedItem="{Binding SelectedFixedSize}" Margin="0,6,0,0"
                                  Visibility="{Binding IsFixedSize, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Save" FontWeight="SemiBold" Margin="0,18,0,6" />
                        <TextBlock Text="Folder" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <Grid Margin="0,2,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputDirectory}" IsReadOnly="True" />
                            <Button Grid.Column="1" Content="…" Command="{Binding ChooseFolderCommand}"
                                    Style="{StaticResource GhostButton}" Padding="9,5" Margin="6,0,0,0" />
                        </Grid>

                        <TextBlock Text="File name" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <TextBox Text="{Binding FileNameTemplateText, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,2" />
                        <TextBlock Text="Tokens: {date} {time} {counter}" Foreground="{StaticResource TextDim}" FontSize="10" Margin="0,0,0,8" />

                        <TextBlock Text="Image format" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding ImageFormats}" SelectedItem="{Binding ImageFormat}" Margin="0,2,0,12" />

                        <Button Content="Save images" Command="{Binding SaveImagesCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" />
                        <Button Content="Save as multi-page PDF" Command="{Binding SavePdfCommand}" Style="{StaticResource GhostButton}" Margin="0,0,0,8" />
                        <Button Content="Open output folder" Command="{Binding OpenOutputFolderCommand}" Style="{StaticResource GhostButton}" />

                        <!-- Edit selected page -->
                        <StackPanel Visibility="{Binding SelectedPage, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="Edit page" FontWeight="SemiBold" Margin="0,20,0,6" />
                            <CheckBox Content="Show crop box" IsChecked="{Binding SelectedPage.IsCropActive}" Margin="0,2" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <Button Content="Auto box" Command="{Binding SelectedPage.AutoCropBoxCommand}"
                                        Style="{StaticResource GhostButton}" Padding="10,5" FontSize="12" Margin="0,0,6,0" />
                                <Button Content="Clear crop" Command="{Binding SelectedPage.ClearCropCommand}"
                                        Style="{StaticResource GhostButton}" Padding="10,5" FontSize="12" />
                            </StackPanel>
                            <TextBlock Text="Brightness" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,6,0,0" />
                            <Slider Minimum="-100" Maximum="100" Value="{Binding SelectedPage.Brightness}"
                                    TickFrequency="10" IsSnapToTickEnabled="True" />
                            <TextBlock Text="Contrast" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,4,0,0" />
                            <Slider Minimum="-100" Maximum="100" Value="{Binding SelectedPage.Contrast}"
                                    TickFrequency="10" IsSnapToTickEnabled="True" />
                            <CheckBox Content="Remove dust &amp; hair" IsChecked="{Binding SelectedPage.RemoveDust}" Margin="0,6,0,2" />
                            <CheckBox Content="Auto levels" IsChecked="{Binding SelectedPage.AutoLevel}" Margin="0,2" />
                            <Button Content="Reset edits" Command="{Binding SelectedPage.ResetEditsCommand}"
                                    Style="{StaticResource GhostButton}" Padding="10,5" FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Theme -->
                        <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,20,0,6" />
                        <CheckBox Content="Light theme" IsChecked="{Binding ThemeIsLight}" Margin="0,2,0,8" />
                        <TextBlock Text="Accent colour" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding AccentSwatches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="30" Height="30" Margin="0,0,8,8" Cursor="Hand"
                                            ToolTip="{Binding Name}"
                                            Command="{Binding DataContext.SetAccentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Hex}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{Binding Brush}" CornerRadius="15" />
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Margin="0,12,0,0" Background="{StaticResource Panel}" CornerRadius="8" Padding="12,8">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDim}" />
        </Border>
    </Grid>
</UserControl>
