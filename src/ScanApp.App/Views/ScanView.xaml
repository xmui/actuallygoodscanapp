<UserControl x:Class="ScanApp.App.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Top bar ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="‹ Back" Command="{Binding BackCommand}" Style="{StaticResource GhostButton}" Padding="12,8" />
                <TextBlock Text="{Binding ModeTitle}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="◼ Cancel" Command="{Binding CancelScanCommand}" Style="{StaticResource GhostButton}"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" Margin="0,0,10,0" />
                <Button Command="{Binding ScanCommand}" Style="{StaticResource PrimaryButton}"
                        MinWidth="160" Padding="22,12"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⤓  Scan" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="  (Enter)" FontSize="12" Opacity="0.8" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Body: filmstrip | preview | options ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Filmstrip -->
            <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="10" Padding="6">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="6,4,6,8">
                        <TextBlock Text="Pages" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Clear" Command="{Binding ClearAllCommand}" HorizontalAlignment="Right"
                                Style="{StaticResource GhostButton}" Padding="8,4" FontSize="11" />
                    </Grid>
                    <ListBox ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelAlt}" CornerRadius="8" Padding="6" Margin="2,4">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding Number, StringFormat='Page {0}'}"
                                                       FontSize="11" Foreground="{StaticResource TextDim}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="⟲" Command="{Binding RotateLeftCommand}" ToolTip="Rotate left"
                                                        Style="{StaticResource GhostButton}" Padding="5,1" FontSize="11" Margin="0,0,3,0" />
                                                <Button Content="⟳" Command="{Binding RotateRightCommand}" ToolTip="Rotate right"
                                                        Style="{StaticResource GhostButton}" Padding="5,1" FontSize="11" Margin="0,0,3,0" />
                                                <Button Content="✕" Command="{Binding DeleteCommand}" ToolTip="Delete page"
                                                        Style="{StaticResource GhostButton}" Padding="5,1" FontSize="11" />
                                            </StackPanel>
                                        </Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" MaxHeight="160" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Preview -->
            <Border Grid.Column="1" Margin="12,0" Background="{StaticResource Panel}" CornerRadius="10">
                <Grid>
                    <TextBlock Text="Your scanned pages will appear here.&#10;Press Scan to begin."
                               TextAlignment="Center" Foreground="{StaticResource TextDim}" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SelectedPage, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />
                    <Image Source="{Binding SelectedPage.Preview}" Stretch="Uniform" Margin="18"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
            </Border>

            <!-- Options -->
            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Scanner" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                                      DisplayMemberPath="Name" />
                            <Button Grid.Column="1" Content="⟳" Command="{Binding RefreshDevicesCommand}"
                                    ToolTip="Refresh device list" Style="{StaticResource GhostButton}" Padding="9,5" Margin="6,0,0,0" />
                        </Grid>

                        <TextBlock Text="Scan settings" FontWeight="SemiBold" Margin="0,18,0,6" />
                        <TextBlock Text="Resolution (DPI)" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding DpiOptions}" SelectedItem="{Binding Dpi}" Margin="0,2,0,8" />

                        <CheckBox Content="Colour" IsChecked="{Binding ColorScan}" Foreground="{StaticResource Text}" Margin="0,2" />
                        <CheckBox Content="Duplex (both sides)" IsChecked="{Binding Duplex}" Foreground="{StaticResource Text}"
                                  Margin="0,2" Visibility="{Binding IsFlatbed, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        <CheckBox Content="Auto-straighten (deskew)" IsChecked="{Binding AutoStraighten}" Foreground="{StaticResource Text}" Margin="0,2" />
                        <CheckBox Content="Split multiple photos on glass" IsChecked="{Binding SplitMultiplePhotos}" Foreground="{StaticResource Text}"
                                  Margin="0,2" Visibility="{Binding IsFlatbed, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Crop" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,10,0,2" />
                        <ComboBox ItemsSource="{Binding CropModes}" SelectedItem="{Binding SelectedCropMode}" />
                        <ComboBox ItemsSource="{Binding FixedSizes}" SelectedItem="{Binding SelectedFixedSize}" Margin="0,6,0,0"
                                  Visibility="{Binding IsFixedSize, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Save" FontWeight="SemiBold" Margin="0,18,0,6" />
                        <TextBlock Text="Folder" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <Grid Margin="0,2,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputDirectory}" IsReadOnly="True" />
                            <Button Grid.Column="1" Content="…" Command="{Binding ChooseFolderCommand}"
                                    Style="{StaticResource GhostButton}" Padding="9,5" Margin="6,0,0,0" />
                        </Grid>

                        <TextBlock Text="File name" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <TextBox Text="{Binding FileNameTemplateText, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,2" />
                        <TextBlock Text="Tokens: {date} {time} {counter}" Foreground="{StaticResource TextDim}" FontSize="10" Margin="0,0,0,8" />

                        <TextBlock Text="Image format" Foreground="{StaticResource TextDim}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding ImageFormats}" SelectedItem="{Binding ImageFormat}" Margin="0,2,0,12" />

                        <Button Content="Save images" Command="{Binding SaveImagesCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" />
                        <Button Content="Save as multi-page PDF" Command="{Binding SavePdfCommand}" Style="{StaticResource GhostButton}" Margin="0,0,0,8" />
                        <Button Content="Open output folder" Command="{Binding OpenOutputFolderCommand}" Style="{StaticResource GhostButton}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Margin="0,12,0,0" Background="{StaticResource Panel}" CornerRadius="8" Padding="12,8">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDim}" />
        </Border>
    </Grid>
</UserControl>
