<UserControl x:Class="ScanApp.App.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,60,0,0" HorizontalAlignment="Center">
            <TextBlock Text="Actually Good Scan" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock Text="Pick how you want to scan" FontSize="15"
                       Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Bulk Flatbed -->
            <Button Command="{Binding StartFlatbedCommand}" Width="300" Height="260" Margin="20"
                    Style="{StaticResource GhostButton}" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🗎" FontSize="72" HorizontalAlignment="Center" />
                    <TextBlock Text="Bulk Flatbed" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="240"
                               Foreground="{StaticResource TextDim}" Margin="0,10,0,0"
                               Text="Scan items off the glass one at a time. Swap and press Scan to keep going. Auto-crop &amp; split multiple photos." />
                </StackPanel>
            </Button>

            <!-- Sheetfed -->
            <Button Command="{Binding StartSheetfedCommand}" Width="300" Height="260" Margin="20"
                    Style="{StaticResource GhostButton}" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="📑" FontSize="72" HorizontalAlignment="Center" />
                    <TextBlock Text="Sheetfed (ADF)" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="240"
                               Foreground="{StaticResource TextDim}" Margin="0,10,0,0"
                               Text="Load a stack into the feeder and scan every page in one go. Great for the Epson FF-680W." />
                </StackPanel>
            </Button>
        </StackPanel>

        <TextBlock Grid.Row="2" Margin="0,0,0,28" HorizontalAlignment="Center"
                   Foreground="{StaticResource TextDim}" FontSize="12"
                   Text="Works with Epson FF-680W and Plustek OpticBook A300 Plus · TWAIN / WIA" />
    </Grid>
</UserControl>
